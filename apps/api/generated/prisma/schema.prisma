generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MANAGER
  OFFICE
  WORKER
  SUPPLY
  PURCHASE
  SHIPPING
}

enum AttendanceType {
  CHECK_IN
  TEMP_EXIT
  RETURN_TO_WORK
  CHECK_OUT
}

enum TaskStatus {
  PENDING
  READY
  IN_PROGRESS
  DONE
  ISSUE
  BLOCKED
}

enum SettlementType {
  CREDIT
  CASH
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  label     String
  createdAt DateTime @default(now())
}

model AppUser {
  id              Int           @id @default(autoincrement())
  username        String        @unique
  passwordHash    String
  fullName        String
  firstName       String?
  lastName        String?
  role            UserRole      @default(WORKER)
  active          Boolean       @default(true)
  phone           String?
  baleUserId      String?
  profileImageUrl String?       @db.LongText
  notes           String?       @db.Text
  lastLoginAt     DateTime?
  skills          WorkerSkill[]
  pickedTasks     WorkTask[]    @relation("TaskPickedBy")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([role])
  @@index([active])
  @@index([phone])
  @@index([baleUserId])
}

model WorkerSkill {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  stage     String
  createdAt DateTime @default(now())

  @@unique([userId, stage])
  @@index([stage])
}

model Customer {
  id        Int             @id @default(autoincrement())
  code      String          @unique
  name      String
  phone     String?
  address   String?
  notes     String?         @db.Text
  orders    WorkshopOrder[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model WorkshopOrder {
  id                    Int                    @id @default(autoincrement())
  code                  String                 @unique
  customerId            Int
  customer              Customer               @relation(fields: [customerId], references: [id])
  settlementType        SettlementType         @default(CREDIT)
  status                String                 @default("ACTIVE")
  satisfactionStatus    String                 @default("NOT_READY")
  notes                 String?                @db.Text
  productionStartedAt   DateTime?
  productionFinishedAt  DateTime?
  deliveredAt           DateTime?
  satisfactionDueAt     DateTime?
  closedAt              DateTime?
  rollers               Roller[]
  satisfactionFeedbacks SatisfactionFeedback[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([status])
  @@index([createdAt])
}

model SatisfactionFeedback {
  id        Int           @id @default(autoincrement())
  orderId   Int
  order     WorkshopOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  result    String
  reason    String?       @db.Text
  createdAt DateTime      @default(now())

  @@index([orderId])
  @@index([result])
}

model AttendanceEvent {
  id           Int            @id @default(autoincrement())
  userId       Int?
  workerName   String
  type         AttendanceType
  note         String?        @db.Text
  eventAt      DateTime       @default(now())
  eventDateFa  String
  eventTimeFa  String
  eventMonthFa String
  createdAt    DateTime       @default(now())

  @@index([userId])
  @@index([workerName])
  @@index([eventAt])
  @@index([eventDateFa])
  @@index([eventMonthFa])
}

model AttendanceDailySummary {
  id                 Int       @id @default(autoincrement())
  userId             Int?
  workerName         String
  shiftDate          String
  shiftDateFa        String
  shiftMonthFa       String
  checkInAt          DateTime?
  checkOutAt         DateTime?
  lastState          String    @default("شیفت هنوز شروع نشده است")
  earlyArrivalReward Boolean   @default(false)
  endOfDayReward     Boolean   @default(false)
  overtimeMinutes    Int       @default(0)
  tempExitCount      Int       @default(0)
  totalRewardAmount  Int       @default(0)
  notes              String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([workerName, shiftDate])
  @@index([userId])
  @@index([shiftDate])
  @@index([shiftDateFa])
  @@index([shiftMonthFa])
}

model RewardLedger {
  id          Int      @id @default(autoincrement())
  userId      Int?
  workerName  String
  shiftDate   String
  shiftDateFa String
  type        String
  amount      Int      @default(0)
  reason      String
  createdAt   DateTime @default(now())

  @@unique([workerName, shiftDate, type])
  @@index([userId])
  @@index([shiftDate])
  @@index([shiftDateFa])
}

model WorkTask {
  id              String     @id
  rollerId        String
  roller          Roller     @relation(fields: [rollerId], references: [id], onDelete: Cascade)
  sequence        Int        @default(1)
  stage           String
  status          TaskStatus @default(PENDING)
  worker          String?
  pickedByUserId  Int?
  pickedByUser    AppUser?   @relation("TaskPickedBy", fields: [pickedByUserId], references: [id])
  availableAt     DateTime?
  startedAt       DateTime?
  finishedAt      DateTime?
  blockedAt       DateTime?
  blockedReason   String?    @db.Text
  estimatedDays   Int        @default(1)
  dueAt           DateTime?
  completedEarly  Boolean    @default(false)
  delayed         Boolean    @default(false)
  delayNotified   Boolean    @default(false)
  delayDetectedAt DateTime?
  updatedAt       DateTime   @updatedAt
  createdAt       DateTime   @default(now())

  @@index([rollerId])
  @@index([status])
  @@index([stage])
  @@index([pickedByUserId])
  @@index([dueAt])
  @@index([delayed])
}

model IssueReport {
  id          Int       @id @default(autoincrement())
  rollerId    String
  taskId      String?
  stage       String
  description String    @db.Text
  status      String    @default("OPEN")
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  @@index([rollerId])
  @@index([taskId])
  @@index([status])
}

model Roller {
  id                   String         @id
  orderCode            String
  workshopOrderId      Int?
  workshopOrder        WorkshopOrder? @relation(fields: [workshopOrderId], references: [id])
  stage                String
  status               String
  ready                Boolean        @default(false)
  settled              Boolean        @default(false)
  sent                 Boolean        @default(false)
  settlementRecordedAt DateTime?
  sentAt               DateTime?
  shipmentNote         String?
  diameterMm           Float?
  lengthMm             Float?
  material             String?
  thicknessMm          Float?
  requiredStages       Json?
  workTasks            WorkTask[]
  updatedAt            DateTime       @updatedAt
  createdAt            DateTime       @default(now())

  @@index([orderCode])
  @@index([status])
}

model SystemNotification {
  id         Int      @id @default(autoincrement())
  title      String
  message    String   @db.Text
  targetRole String
  sourceType String?
  sourceId   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([targetRole])
  @@index([isRead])
  @@index([createdAt])
}

model Referral {
  id          Int               @id @default(autoincrement())
  title       String
  description String            @db.Text
  targetRole  String
  sourceRole  String            @default("SYSTEM")
  sourceType  String?
  sourceId    String?
  orderCode   String?
  rollerId    String?
  taskId      String?
  issueId     Int?
  status      String            @default("OPEN")
  priority    String            @default("NORMAL")
  completedAt DateTime?
  messages    ReferralMessage[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([targetRole])
  @@index([status])
  @@index([taskId])
  @@index([orderCode])
}

model ReferralMessage {
  id         Int      @id @default(autoincrement())
  referralId Int
  referral   Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  authorRole String
  authorName String?
  message    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([referralId])
}
